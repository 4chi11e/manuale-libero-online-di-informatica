---
import Default from "@astrojs/starlight/components/Head.astro";
---
<Default {...Astro.props} />

<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/contrib/auto-render.min.js" onload="window.triggerRenderMath && window.triggerRenderMath()"></script>

<script>
  // Funzione per unire parentesi e punteggiatura adiacenti alle formule inline evitando a capo sgradevoli
  function wrapInlineMathPunctuation() {
    const katexNodes = document.querySelectorAll('.katex:not(.katex-display)');
    katexNodes.forEach(katex => {
      const parent = katex.parentNode as HTMLElement | null;
      if (!parent || parent.classList.contains('math-no-break')) return;

      const prev = katex.previousSibling;
      const next = katex.nextSibling;

      let prevMatchText = '';
      let nextMatchText = '';

      if (prev && prev.nodeType === Node.TEXT_NODE && prev.nodeValue) {
        const match = prev.nodeValue.match(/([\(\[\{]\s*)$/);
        if (match) {
          prevMatchText = match[1];
        }
      }

      if (next && next.nodeType === Node.TEXT_NODE && next.nodeValue) {
        const match = next.nodeValue.match(/^(\s*[\)\]\}:,\.]+)/);
        if (match) {
          nextMatchText = match[1];
        }
      }

      if (prevMatchText || nextMatchText) {
        const wrapper = document.createElement('span');
        wrapper.className = 'math-no-break';

        if (prevMatchText && prev && prev.nodeValue) {
          prev.nodeValue = prev.nodeValue.slice(0, -prevMatchText.length);
          wrapper.appendChild(document.createTextNode(prevMatchText));
        }

        parent.insertBefore(wrapper, katex);
        wrapper.appendChild(katex);

        if (nextMatchText && next && next.nodeValue) {
          next.nodeValue = next.nodeValue.slice(nextMatchText.length);
          wrapper.appendChild(document.createTextNode(nextMatchText));
        }
      }
    });
  }

  // Funzione per il rendering dinamico delle formule matematiche KaTeX (anche nei blocchi HTML come le soluzioni)
  function renderMath() {
    if (typeof (window as any).renderMathInElement === 'function') {
      (window as any).renderMathInElement(document.body, {
        delimiters: [
          {left: '$$', right: '$$', display: true},
          {left: '$', right: '$', display: false},
          {left: '\\(', right: '\\)', display: false},
          {left: '\\[', right: '\\]', display: true}
        ],
        throwOnError: false
      });
    }
    wrapInlineMathPunctuation();
    setTimeout(wrapInlineMathPunctuation, 50);
  }

  (window as any).triggerRenderMath = renderMath;


  // Script globale per gestire le soluzioni collassabili (subnetting ed esercizi)
  function setupCollapsibles() {
    renderMath();
    const containers = document.querySelectorAll('.soluzione-container');
    containers.forEach(container => {
      const header = container.querySelector('.soluzione-header, .soluzione-toggler');
      const content = container.querySelector('.soluzione-content, .soluzione');
      const icon = container.querySelector('.soluzione-icon');
      const titleSpan = header;

      if (!header || !content || header.hasAttribute('data-quiz-active')) return;
      header.setAttribute('data-quiz-active', 'true');

      header.addEventListener('click', () => {
        const isVisible = content.classList.toggle('soluzione__visibile');
        content.classList.toggle('visible', isVisible);
        if (isVisible) {
          renderMath();
        }
        
        if (icon) {
          icon.textContent = isVisible ? '▲' : '▼';
        }
        
        if (titleSpan) {
          const text = titleSpan.textContent || '';
          if (text.startsWith('Visualizza')) {
            titleSpan.textContent = text.replace('Visualizza', 'Nascondi');
          } else if (text.startsWith('Nascondi')) {
            titleSpan.textContent = text.replace('Nascondi', 'Visualizza');
          }
        }
      });
    });
  }

  // Script per lo strumento di crittografia antica (Atbash, Albam, Atbah)
  function setupCryptoTool() {
    const clearTextEl = document.getElementById('clear-text') as HTMLTextAreaElement;
    const cipherTextEl = document.getElementById('cipher-text') as HTMLTextAreaElement;
    const btnEncrypt = document.getElementById('btn-encrypt');
    const btnDecrypt = document.getElementById('btn-decrypt');
    const btnClear = document.getElementById('btn-clear');

    if (!clearTextEl || !cipherTextEl || !btnEncrypt || !btnDecrypt || !btnClear) return;
    if (btnEncrypt.hasAttribute('data-crypto-active')) return;
    btnEncrypt.setAttribute('data-crypto-active', 'true');

    const ALPHABET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    const ALPHABET_ALBAM = 'NOPQRSTUVWXYZABCDEFGHIJKLM';
    const ALPHABET_ATBAH = 'IHGFNDCBARQPOEMLKJZYXWVUTS';

    function atbash(text: string) {
      return text.toUpperCase().split('').map(char => {
        const idx = ALPHABET.indexOf(char);
        return idx > -1 ? ALPHABET.charAt(25 - idx) : char;
      }).join('');
    }

    function albam(text: string) {
      return text.toUpperCase().split('').map(char => {
        const idx = ALPHABET.indexOf(char);
        return idx > -1 ? ALPHABET_ALBAM.charAt(idx) : char;
      }).join('');
    }

    function atbah(text: string) {
      return text.toUpperCase().split('').map(char => {
        const idx = ALPHABET.indexOf(char);
        return idx > -1 ? ALPHABET_ATBAH.charAt(idx) : char;
      }).join('');
    }

    function getSelectedCipher() {
      const activeRadio = document.querySelector('input[name="cipher-type"]:checked') as HTMLInputElement;
      return activeRadio ? activeRadio.value : 'atbash';
    }

    function processText(isEncryption: boolean) {
      const sourceText = isEncryption ? clearTextEl.value : cipherTextEl.value;
      const cipher = getSelectedCipher();
      let result = '';

      if (cipher === 'atbash') {
        result = atbash(sourceText);
      } else if (cipher === 'albam') {
        result = albam(sourceText);
      } else if (cipher === 'atbah') {
        result = atbah(sourceText);
      }

      if (isEncryption) {
        cipherTextEl.value = result;
      } else {
        clearTextEl.value = result;
      }
    }

    btnEncrypt.addEventListener('click', () => processText(true));
    btnDecrypt.addEventListener('click', () => processText(false));
    btnClear.addEventListener('click', () => {
      clearTextEl.value = '';
      cipherTextEl.value = '';
    });
  }

  // Script globale per gestire i popups modali delle immagini
  function setupModals() {
    const openers = document.querySelectorAll('.modal__opener');
    openers.forEach(opener => {
      if (opener.hasAttribute('data-modal-active')) return;
      opener.setAttribute('data-modal-active', 'true');
      opener.addEventListener('click', (event) => {
        const target = event.currentTarget as HTMLElement;
        const targetId = target.getAttribute('aprire');
        if (targetId) {
          const modal = document.querySelector(targetId) as HTMLElement;
          if (modal) {
            // Spostiamo il modal sotto il body per uscire dal contesto isolato (stacking context) di Starlight
            if (modal.parentElement !== document.body) {
              document.body.appendChild(modal);
            }
            modal.classList.add('modal--visibile');
          }
        }
      });
    });

    const closers = document.querySelectorAll('.modal__closer, .modal__close');
    closers.forEach(closer => {
      if (closer.hasAttribute('data-modal-active')) return;
      closer.setAttribute('data-modal-active', 'true');
      closer.addEventListener('click', (event) => {
        const target = event.currentTarget as HTMLElement;
        const targetId = target.getAttribute('chiudere');
        if (targetId) {
          const modal = document.querySelector(targetId);
          if (modal) {
            modal.classList.remove('modal--visibile');
          }
        } else {
          const modal = target.closest('.modal');
          if (modal) {
            modal.classList.remove('modal--visibile');
          }
        }
      });
    });

    // Chiudi il modal cliccando all'esterno del contenuto
    if (!(window as any).hasModalOutsideClickRegistered) {
      (window as any).hasModalOutsideClickRegistered = true;
      window.addEventListener('click', (event) => {
        const target = event.target as HTMLElement;
        if (target && target.classList.contains('modal')) {
          target.classList.remove('modal--visibile');
        }
      });
    }
  }

  function detectHomepage() {
    const path = window.location.pathname;
    const isHome = path === '/' || 
                   path === '/index.html' || 
                   path.endsWith('/manuale-libero-online-di-informatica/') || 
                   path.endsWith('/manuale-libero-online-di-informatica/index.html');
    if (isHome) {
      document.documentElement.classList.add('is-homepage');
    } else {
      document.documentElement.classList.remove('is-homepage');
    }
  }

  function setupSidebarGroupLinks() {
    const sidebar = document.querySelector('nav');
    if (!sidebar) return;

    const summaries = sidebar.querySelectorAll('summary');
    summaries.forEach(summary => {
      if (summary.hasAttribute('data-group-link-active')) return;
      summary.setAttribute('data-group-link-active', 'true');

      const details = summary.parentElement;
      if (details && details.tagName === 'DETAILS') {
        const firstLink = details.querySelector('ul a') as HTMLAnchorElement | null;
        if (firstLink) {
          const firstLinkLabel = firstLink.querySelector('span')?.textContent?.trim().toLowerCase();
          const groupLabelSpan = summary.querySelector('.group-label span') as HTMLElement | null;
          const groupLabelText = groupLabelSpan?.textContent?.trim().toLowerCase();

          // Se l'etichetta del primo link corrisponde a quella del gruppo, o è "spiegazione", o uniamo "modello iso/osi" con "iso/osi"
          const isMatch = groupLabelText === firstLinkLabel || 
                          firstLinkLabel === 'spiegazione' ||
                          (groupLabelText === 'modello iso/osi' && firstLinkLabel === 'iso/osi');
          if (groupLabelSpan && isMatch) {
            const href = firstLink.getAttribute('href');
            if (href) {
              const a = document.createElement('a');
              a.href = href;
              a.className = 'group-link-header';
              a.style.display = 'inline-block';
              a.style.color = 'inherit';
              a.style.textDecoration = 'none';

              if (firstLink.getAttribute('aria-current') === 'page') {
                a.setAttribute('aria-current', 'page');
              }

              groupLabelSpan.parentNode?.replaceChild(a, groupLabelSpan);
              a.appendChild(groupLabelSpan);

              a.addEventListener('click', (e) => {
                e.stopPropagation();
              });

              const li = firstLink.closest('li');
              if (li) {
                li.style.display = 'none';
              }
            }
          }
        }
      }
    });
  }

  // Eseguiamo i setup al caricamento e ad ogni navigazione di Starlight
  detectHomepage();
  setupCollapsibles();
  setupCryptoTool();
  setupModals();
  setupSidebarGroupLinks();
  renderMath();

  document.addEventListener('astro:page-load', () => {
    detectHomepage();
    setupCollapsibles();
    setupCryptoTool();
    setupModals();
    setupSidebarGroupLinks();
    renderMath();
  });

  // Se i file JS CDN caricano asincronamente
  window.addEventListener('load', () => {
    renderMath();
  });
</script>
